generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
}

// =====================================================================
// ENUMS
// =====================================================================

enum ErrorSource {
  CURATED
  LLM_GENERATED
  FIELD_REPORTED
}

enum ErrorStatus {
  ACTIVE
  DRAFT
  DEPRECATED
}

enum ErrorSeverity {
  LOW
  MED
  HIGH
  CRITICAL
}

// ---------------------------------------------------------------------
// v9 — Guides pipeline (ADR-116..125)
// ---------------------------------------------------------------------

enum GuideStatus {
  UPLOADED
  EXTRACTING
  EXTRACTION_FAILED
  GENERATING_SOLUTIONS
  GENERATION_FAILED
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum GuideQuestionStatus {
  EXTRACTED // salió del pipeline, sin revisar
  NEEDS_REVIEW // baja confianza (topic <0.85 o pauta divergente del solucionario PDF)
  APPROVED // profe aprobó pauta + topic
  EXCLUDED // profe la sacó de la guía publicada
}

enum SolutionSource {
  PDF_PROVIDED // venía en el PDF, normalizada
  LLM_GENERATED // generada por Sonnet
  TEACHER_EDITED // editada por el profe en el wizard
}

enum SubmissionStatus {
  UPLOADED
  TRANSCRIBING
  GRADING
  GRADED
  FAILED
}

// =====================================================================
// AUTH / USERS
// =====================================================================

model User {
  id                     String    @id @default(uuid())
  supabaseUid            String?   @unique @map("supabase_uid")
  email                  String    @unique
  authRole               String?   @map("auth_role")
  fullName               String?   @map("full_name")
  locale                 String    @default("es-CL")
  passwordHash           String?   @map("password_hash")
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  tokenVersion           Int       @default(0) @map("token_version")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  teacher Teacher?
  student Student?
  parent  Parent?

  errorReports AttemptErrorReport[]

  @@map("users")
}

model Teacher {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  displayName String?  @map("display_name")
  bio         String?
  createdAt   DateTime @default(now()) @map("created_at")

  user           User             @relation(fields: [userId], references: [id])
  courseTeachers CourseTeacher[]
  alerts         TeacherAlert[]
  assignments    Assignment[]
  integrations   SchoolIntegration[]
  guides         Guide[]

  @@map("teachers")
}

model Student {
  id            String    @id @default(uuid())
  userId        String?   @unique @map("user_id")
  externalEmail String?   @map("external_email")
  displayName   String    @map("display_name")
  birthYear     Int?      @map("birth_year")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  user              User?               @relation(fields: [userId], references: [id])
  enrollments       Enrollment[]
  attempts          Attempt[]
  parentLinks       ParentLink[]
  topicMastery      StudentTopicMastery[]
  assignmentTargets AssignmentTarget[]
  guideSubmissions  GuideSubmission[]

  @@map("students")
}

model Parent {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id])
  links ParentLink[]

  @@map("parents")
}

model ParentLink {
  parentId     String    @map("parent_id")
  studentId    String    @map("student_id")
  relationship String
  confirmedAt  DateTime? @map("confirmed_at")

  parent  Parent  @relation(fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@id([parentId, studentId])
  @@map("parent_links")
}

// =====================================================================
// ORGANIZACIÓN ESCOLAR (multi-tenant)
// =====================================================================

model Organization {
  id           String   @id @default(uuid())
  name         String
  country      String   @default("CL")
  billingEmail String?  @map("billing_email")
  plan         String   @default("FREE")
  createdAt    DateTime @default(now()) @map("created_at")

  schools School[]

  @@map("organizations")
}

model School {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  rbd            String?  @unique
  city           String?
  region         String?
  domain         String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id])
  courses      Course[]
  integrations SchoolIntegration[]

  @@index([organizationId])
  @@index([domain])
  @@map("schools")
}

model Course {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  subjectId    String    @map("subject_id")
  name         String
  gradeLevel   Int       @map("grade_level")
  letter       String?   @map("letter")
  academicYear Int       @map("academic_year")
  externalId   String?   @map("external_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  archivedAt   DateTime? @map("archived_at")

  school         School          @relation(fields: [schoolId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  courseTeachers CourseTeacher[]
  enrollments    Enrollment[]
  assignments    Assignment[]
  attempts       Attempt[]
  alerts         TeacherAlert[]
  invites        ClassroomInvite[]
  guides         Guide[]

  @@index([schoolId, academicYear])
  @@index([subjectId])
  @@map("courses")
}

model CourseTeacher {
  courseId  String   @map("course_id")
  teacherId String   @map("teacher_id")
  role      String   @default("LEAD")
  addedAt   DateTime @default(now()) @map("added_at")

  course  Course  @relation(fields: [courseId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@id([courseId, teacherId])
  @@map("course_teachers")
}

model Enrollment {
  id        String    @id @default(uuid())
  courseId  String    @map("course_id")
  studentId String    @map("student_id")
  status    String    @default("ACTIVE")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  course  Course  @relation(fields: [courseId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
  @@index([studentId])
  @@map("enrollments")
}

model ClassroomInvite {
  id        String    @id @default(cuid())
  code      String    @unique @default(cuid())
  courseId  String    @map("course_id")
  createdBy String    @map("created_by")
  expiresAt DateTime? @map("expires_at")
  maxUses   Int?      @map("max_uses")
  useCount  Int       @default(0) @map("use_count")
  createdAt DateTime  @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id])

  @@index([code])
  @@index([courseId])
  @@map("classroom_invites")
}

// =====================================================================
// TAXONOMÍA DE ERRORES (Domain/Subdomain hierarchy)
// =====================================================================

model Domain {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?

  subdomains Subdomain[]
  topics     Topic[]
  errorTags  ErrorTag[]

  @@map("domains")
}

model Subdomain {
  id       String @id @default(uuid())
  domainId String @map("domain_id")
  code     String
  name     String

  domain Domain  @relation(fields: [domainId], references: [id])
  topics Topic[]

  @@unique([domainId, code])
  @@index([domainId])
  @@map("subdomains")
}

// =====================================================================
// CURRICULUM (multi-materia, multi-grado)
// =====================================================================

model Subject {
  id       String @id @default(uuid())
  code     String @unique
  name     String
  language String @default("es")

  curricula Curriculum[]
  courses   Course[]

  @@map("subjects")
}

model Curriculum {
  id            String    @id @default(uuid())
  subjectId     String    @map("subject_id")
  country       String    @default("CL")
  name          String
  version       String    @default("1.0")
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  subject Subject @relation(fields: [subjectId], references: [id])
  units   Unit[]

  @@unique([subjectId, country, version])
  @@map("curricula")
}

model OfficialOACode {
  id          String @id @default(uuid())
  code        String @unique
  description String
  grade       Int

  topics Topic[]

  @@index([grade])
  @@map("official_oa_codes")
}

model Unit {
  id           String @id @default(uuid())
  curriculumId String @map("curriculum_id")
  gradeLevel   Int    @map("grade_level")
  sequence     Int
  code         String
  name         String
  description  String?

  curriculum Curriculum @relation(fields: [curriculumId], references: [id])
  topics     Topic[]

  @@unique([curriculumId, code])
  @@index([curriculumId, gradeLevel, sequence])
  @@map("units")
}

model Topic {
  id               String    @id @default(uuid())
  unitId           String    @map("unit_id")
  subdomainId      String?   @map("subdomain_id")
  domainId         String?   @map("domain_id")
  code             String
  name             String
  description      String?
  bktPL0           Float     @default(0.3) @map("bkt_p_l0")
  bktPTransit      Float     @default(0.1) @map("bkt_p_transit")
  bktPSlip         Float     @default(0.1) @map("bkt_p_slip")
  bktPGuess        Float     @default(0.2) @map("bkt_p_guess")
  bktCalibratedAt  DateTime? @map("bkt_calibrated_at")

  unit          Unit                  @relation(fields: [unitId], references: [id])
  subdomain     Subdomain?            @relation(fields: [subdomainId], references: [id])
  domain        Domain?               @relation(fields: [domainId], references: [id])
  exercises     Exercise[]
  prerequisites TopicPrerequisite[]   @relation("TopicPrereqs")
  dependents    TopicPrerequisite[]   @relation("PrereqTopics")
  topicMastery   StudentTopicMastery[]
  alerts         TeacherAlert[]
  oaCodes        OfficialOACode[]
  guideQuestions GuideQuestion[]

  @@unique([unitId, code])
  @@index([subdomainId])
  @@index([domainId])
  @@map("topics")
}

model TopicPrerequisite {
  topicId              String @map("topic_id")
  prerequisiteTopicId  String @map("prerequisite_topic_id")

  topic        Topic @relation("TopicPrereqs", fields: [topicId], references: [id])
  prerequisite Topic @relation("PrereqTopics", fields: [prerequisiteTopicId], references: [id])

  @@id([topicId, prerequisiteTopicId])
  @@map("topic_prerequisites")
}

// =====================================================================
// EJERCICIOS Y ASIGNACIONES
// =====================================================================

model Exercise {
  id                  String    @id @default(uuid())
  topicId             String    @map("topic_id")
  source              String    @default("SYSTEM")
  createdByTeacherId  String?   @map("created_by_teacher_id")
  content             Json
  language            String    @default("es")
  irtA                Float     @default(1.0) @map("irt_a")
  irtB                Float     @default(0.0) @map("irt_b")
  irtCalibratedAt     DateTime? @map("irt_calibrated_at")
  status              String    @default("ACTIVE")
  createdAt           DateTime  @default(now()) @map("created_at")

  topic               Topic                @relation(fields: [topicId], references: [id])
  attempts            Attempt[]
  assignmentExercises AssignmentExercise[]
  targetErrorTags     ErrorTag[]           @relation("ExerciseTargetErrors")
  guideQuestion       GuideQuestion?

  @@index([topicId, source])
  @@index([topicId, status])
  @@map("exercises")
}

model Assignment {
  id                  String    @id @default(uuid())
  courseId            String?   @map("course_id")
  createdByTeacherId  String    @map("created_by_teacher_id")
  title               String
  reason              String
  kind                String    @default("EXERCISES") // EXERCISES | GUIDE
  dueAt               DateTime? @map("due_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  course             Course?              @relation(fields: [courseId], references: [id])
  teacher            Teacher              @relation(fields: [createdByTeacherId], references: [id])
  targets            AssignmentTarget[]
  assignmentExercises AssignmentExercise[]
  attempts            Attempt[]
  guide              Guide?

  @@index([courseId])
  @@index([createdByTeacherId])
  @@map("assignments")
}

model AssignmentTarget {
  assignmentId String @map("assignment_id")
  studentId    String @map("student_id")
  status       String @default("PENDING")

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@id([assignmentId, studentId])
  @@index([studentId])
  @@map("assignment_targets")
}

model AssignmentExercise {
  assignmentId String @map("assignment_id")
  exerciseId   String @map("exercise_id")
  sequence     Int

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  exercise   Exercise   @relation(fields: [exerciseId], references: [id])

  @@id([assignmentId, sequence])
  @@map("assignment_exercises")
}

// =====================================================================
// INTENTOS Y TELEMETRÍA RELACIONAL
// =====================================================================

model Attempt {
  id               String    @id @default(uuid())
  assignmentId     String?   @map("assignment_id")
  exerciseId       String?   @map("exercise_id")
  studentId        String    @map("student_id")
  courseId         String?   @map("course_id")
  inputMode        String    @default("DIGITAL") @map("input_mode")
  status           String    @default("PENDING")
  finalAnswer      String?   @map("final_answer")
  isCorrect        Boolean   @map("is_correct")
  classifierSource String    @default("RULE") @map("classifier_source")
  errorTagId       String?   @map("error_tag_id")
  confidence       Float?
  ocrConfidence    Float?    @map("ocr_confidence")
  ocrProvider      String?   @map("ocr_provider")
  llmJobId         String?   @map("llm_job_id")
  traceId          String    @default(uuid()) @map("trace_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  classifiedAt     DateTime? @map("classified_at")
  // Mutable record (status PENDING→GRADED→CLASSIFIED, error_tag_id set later by the
  // async classifier / adhoc_solver, which write `updated_at` via raw SQL).
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  assignment      Assignment?      @relation(fields: [assignmentId], references: [id])
  exercise        Exercise?        @relation(fields: [exerciseId], references: [id])
  student         Student          @relation(fields: [studentId], references: [id])
  course          Course?          @relation(fields: [courseId], references: [id])
  errorTag        ErrorTag?        @relation(fields: [errorTagId], references: [id])
  steps           AttemptStep[]
  guideSubmission GuideSubmission?
  errorReports    AttemptErrorReport[]

  @@index([studentId])
  @@index([courseId])
  @@index([exerciseId, createdAt])
  @@index([errorTagId])
  @@map("attempts")
}

// v8 C4 — a student/teacher disagreeing with the classifier reports the correct
// error tag from the catalog. Recorded as field evidence (ErrorSource.FIELD_REPORTED)
// without overwriting the original classification on the Attempt.
model AttemptErrorReport {
  id           String      @id @default(uuid())
  attemptId    String      @map("attempt_id")
  errorTagId   String      @map("error_tag_id")
  reportedById String?     @map("reported_by_id")
  comment      String?
  source       ErrorSource @default(FIELD_REPORTED)
  createdAt    DateTime    @default(now()) @map("created_at")

  attempt    Attempt  @relation(fields: [attemptId], references: [id])
  errorTag   ErrorTag @relation(fields: [errorTagId], references: [id])
  reportedBy User?    @relation(fields: [reportedById], references: [id])

  @@index([attemptId])
  @@index([errorTagId])
  @@map("attempt_error_reports")
}

model AttemptStep {
  id           String   @id @default(uuid())
  attemptId    String   @map("attempt_id")
  stepIndex    Int      @map("step_index")
  contentLatex String   @map("content_latex")
  durationMs   Int?     @map("duration_ms")
  isCorrect    Boolean? @map("is_correct")
  errorSubtag  String?  @map("error_subtag")
  errorTagId   String?  @map("error_tag_id")
  createdAt    DateTime @default(now()) @map("created_at")

  attempt  Attempt   @relation(fields: [attemptId], references: [id])
  errorTag ErrorTag? @relation(fields: [errorTagId], references: [id])

  @@unique([attemptId, stepIndex])
  @@index([errorTagId])
  @@map("attempt_steps")
}

model ErrorTag {
  id               String        @id @default(uuid())
  code             String        @unique
  name             String        @default("")
  topicScope       String?       @map("topic_scope")
  description      String
  domainId         String?       @map("domain_id")
  subdomainCode    String?       @map("subdomain_code")
  source           ErrorSource   @default(CURATED)
  status           ErrorStatus   @default(ACTIVE)
  severity         ErrorSeverity @default(MED)
  applicableGrades Int[]         @map("applicable_grades")
  evidenceRequired String[]      @map("evidence_required")
  diagnosticHint   String?       @map("diagnostic_hint")
  remediation      String?
  references       String[]
  deprecatedById   String?       @map("deprecated_by_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")

  domain       Domain?    @relation(fields: [domainId], references: [id])
  deprecatedBy ErrorTag?  @relation("Deprecation", fields: [deprecatedById], references: [id])
  successors   ErrorTag[] @relation("Deprecation")

  attempts            Attempt[]
  attemptSteps        AttemptStep[]
  targetedByExercises Exercise[]           @relation("ExerciseTargetErrors")
  errorReports        AttemptErrorReport[]
  submissionOverrides GuideSubmission[]    @relation("SubmissionErrorOverride")

  @@index([domainId, status])
  @@index([source])
  @@map("error_tags")
}

// =====================================================================
// MASTERY
// =====================================================================

model StudentTopicMastery {
  studentId     String    @map("student_id")
  topicId       String    @map("topic_id")
  pKnown        Float     @default(0.3) @map("p_known")
  pSlip         Float     @default(0.1) @map("p_slip")
  pGuess        Float     @default(0.2) @map("p_guess")
  pTransit      Float     @default(0.1) @map("p_transit")
  attemptsCount Int       @default(0) @map("attempts_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  trend7d       Float?    @map("trend_7d")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])
  topic   Topic   @relation(fields: [topicId], references: [id])

  @@id([studentId, topicId])
  @@index([topicId])
  @@index([lastAttemptAt])
  @@map("student_topic_mastery")
}

// =====================================================================
// ALERTS
// =====================================================================

model TeacherAlert {
  id         String    @id @default(uuid())
  teacherId  String    @map("teacher_id")
  courseId   String    @map("course_id")
  topicId    String?   @map("topic_id")
  studentId  String?   @map("student_id")
  alertType  String    @map("alert_type")
  severity   String    @default("MED")
  payload    Json
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by")

  teacher Teacher @relation(fields: [teacherId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])
  topic   Topic?  @relation(fields: [topicId], references: [id])

  @@index([teacherId, resolvedAt])
  @@index([courseId, alertType, createdAt])
  @@map("teacher_alerts")
}

// =====================================================================
// INTEGRACIONES SIS/LMS
// =====================================================================

model SchoolIntegration {
  id                   String    @id @default(uuid())
  schoolId             String    @map("school_id")
  provider             String
  status               String    @default("DRAFT")
  cadence              String    @default("MANUAL")
  config               Json      @default("{}")
  lastSyncAt           DateTime? @map("last_sync_at")
  lastSyncError        String?   @map("last_sync_error")
  createdByTeacherId   String?   @map("created_by_teacher_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  school    School          @relation(fields: [schoolId], references: [id])
  teacher   Teacher?        @relation(fields: [createdByTeacherId], references: [id])
  externalIds ExternalIdMap[]

  @@unique([schoolId, provider])
  @@index([status])
  @@map("school_integrations")
}

model ExternalIdMap {
  id                   String    @id @default(uuid())
  schoolIntegrationId  String    @map("school_integration_id")
  provider             String
  externalEntityType   String    @map("external_entity_type")
  externalId           String    @map("external_id")
  internalEntityType   String    @map("internal_entity_type")
  internalEntityId     String    @map("internal_entity_id")
  firstSeenAt          DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt           DateTime  @default(now()) @map("last_seen_at")
  deletedAt            DateTime? @map("deleted_at")

  integration SchoolIntegration @relation(fields: [schoolIntegrationId], references: [id])

  @@unique([provider, externalEntityType, externalId, schoolIntegrationId])
  @@index([internalEntityType, internalEntityId])
  @@map("external_id_maps")
}

// =====================================================================
// v9 — GUIDES PIPELINE (PDF → pauta IA → quiz con fotos → corrección)
// Migración aditiva v9_guides_pipeline. ADRs 116-125. Sin renames.
// =====================================================================

model Guide {
  id                     String      @id @default(uuid())
  courseId               String      @map("course_id")
  createdByTeacherId     String      @map("created_by_teacher_id")
  title                  String
  description            String?
  status                 GuideStatus @default(UPLOADED)
  sourcePdfKey           String      @map("source_pdf_key") // S3 guides/uploads/
  sourcePdfPages         Int?        @map("source_pdf_pages")
  sourceKind             String?     @map("source_kind") // SCANNED | DIGITAL | MIXED (Gemini precheck)
  latexKey               String?     @map("latex_key") // S3 .tex generado (ADR-117)
  extractionConfidence   Float?      @map("extraction_confidence")
  extractionModel        String?     @map("extraction_model")
  failureReason          String?     @map("failure_reason")
  questionCount          Int         @default(0) @map("question_count")
  maxResubmissions       Int         @default(2) @map("max_resubmissions")
  showSolutionAfterGrade Boolean     @default(false) @map("show_solution_after_grade")
  assignmentId           String?     @unique @map("assignment_id") // set al publicar (kind=GUIDE)
  dueAt                  DateTime?   @map("due_at")
  publishedAt            DateTime?   @map("published_at")
  traceId                String      @default(uuid()) @map("trace_id")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  archivedAt             DateTime?   @map("archived_at")

  course      Course            @relation(fields: [courseId], references: [id])
  teacher     Teacher           @relation(fields: [createdByTeacherId], references: [id])
  assignment  Assignment?       @relation(fields: [assignmentId], references: [id])
  questions   GuideQuestion[]
  submissions GuideSubmission[]

  @@index([courseId, status])
  @@index([createdByTeacherId])
  @@map("guides")
}

model GuideQuestion {
  id                    String              @id @default(uuid())
  guideId               String              @map("guide_id")
  sequence              Int
  label                 String? // "1.a", "3", "II.2"
  statementLatex        String              @map("statement_latex")
  statementJson         Json?               @map("statement_json") // sub-partes, opciones, tablas
  figureKeys            String[]            @map("figure_keys") // crops S3 guides/{id}/figures/
  providedAnswer        String?             @map("provided_answer") // respuesta del PDF
  providedSolutionLatex String?             @map("provided_solution_latex") // solucionario del PDF
  points                Float               @default(1.0)
  status                GuideQuestionStatus @default(EXTRACTED)
  topicId               String?             @map("topic_id")
  domainId              String?             @map("domain_id")
  subdomainId           String?             @map("subdomain_id")
  topicConfidence       Float?              @map("topic_confidence")
  topicSource           String?             @map("topic_source") // LLM | TEACHER
  exerciseId            String?             @unique @map("exercise_id") // materializado al publicar (ADR-116)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  guide       Guide             @relation(fields: [guideId], references: [id])
  topic       Topic?            @relation(fields: [topicId], references: [id])
  exercise    Exercise?         @relation(fields: [exerciseId], references: [id])
  solutions   GuideSolution[]
  submissions GuideSubmission[]

  @@unique([guideId, sequence])
  @@index([topicId])
  @@map("guide_questions")
}

model GuideSolution {
  id                 String         @id @default(uuid())
  guideQuestionId    String         @map("guide_question_id")
  version            Int
  isCurrent          Boolean        @default(true) @map("is_current")
  source             SolutionSource
  finalAnswer        String         @map("final_answer")
  stepsJson          Json           @map("steps_json") // formato canónico ADR-118
  solutionLatex      String?        @map("solution_latex") // render derivado, no fuente de verdad
  expectedErrorTags  String[]       @map("expected_error_tags") // codes de ErrorTag
  generatedByModel   String?        @map("generated_by_model")
  promptVersion      String?        @map("prompt_version")
  validationNotes    String?        @map("validation_notes") // discrepancias vs solucionario del PDF
  createdByTeacherId String?        @map("created_by_teacher_id")
  createdAt          DateTime       @default(now()) @map("created_at")

  question GuideQuestion @relation(fields: [guideQuestionId], references: [id])

  @@unique([guideQuestionId, version])
  @@index([guideQuestionId, isCurrent])
  @@map("guide_solutions")
}

model GuideSubmission {
  id                      String           @id @default(uuid())
  guideId                 String           @map("guide_id")
  guideQuestionId         String           @map("guide_question_id")
  studentId               String           @map("student_id")
  attemptNumber           Int              @default(1) @map("attempt_number")
  status                  SubmissionStatus @default(UPLOADED)
  photoKeys               String[]         @map("photo_keys") // 1-3 fotos S3, lifecycle 30d
  transcriptionLatex      String?          @map("transcription_latex")
  transcriptionJson       Json?            @map("transcription_json") // pasos ordenados
  transcriptionConfidence Float?           @map("transcription_confidence")
  alignmentJson           Json?            @map("alignment_json") // paso alumno ↔ checkpoint pauta + veredictos
  solutionVersion         Int?             @map("solution_version") // versión de pauta usada
  score                   Float?
  isCorrect               Boolean?         @map("is_correct")
  attemptId               String?          @unique @map("attempt_id") // ADR-120
  overrideErrorTagId      String?          @map("override_error_tag_id") // teacher manual override (C11)
  overrideById            String?          @map("override_by_id") // teacher who overrode
  overrideAt              DateTime?        @map("override_at")
  modelUsed               String?          @map("model_used")
  failureReason           String?          @map("failure_reason")
  traceId                 String           @default(uuid()) @map("trace_id")
  gradedAt                DateTime?        @map("graded_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  guide            Guide         @relation(fields: [guideId], references: [id])
  question         GuideQuestion @relation(fields: [guideQuestionId], references: [id])
  student          Student       @relation(fields: [studentId], references: [id])
  attempt          Attempt?      @relation(fields: [attemptId], references: [id])
  overrideErrorTag ErrorTag?     @relation("SubmissionErrorOverride", fields: [overrideErrorTagId], references: [id])

  @@unique([guideQuestionId, studentId, attemptNumber])
  @@index([guideId, studentId])
  @@index([status])
  @@index([overrideErrorTagId])
  @@map("guide_submissions")
}

// ──────────────────────────────────────────────────────────────────────────────
// OBSERVABILITY
// ──────────────────────────────────────────────────────────────────────────────

model CostEvent {
  id                       String   @id @default(cuid())
  worker                   String
  model                    String
  inputTokens              Int      @default(0) @map("input_tokens")
  outputTokens             Int      @default(0) @map("output_tokens")
  cacheCreationInputTokens Int      @default(0) @map("cache_creation_input_tokens")
  cacheReadInputTokens     Int      @default(0) @map("cache_read_input_tokens")
  costUsd                  Float    @map("cost_usd")
  traceId                  String   @default("") @map("trace_id")
  createdAt                DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([model, createdAt])
  @@map("cost_events")
}
