// =====================================================================
// SuperProfes / Innova — PostgreSQL schema (v7.1)
// Source of truth documental. Prisma schema debe estar en paridad con este DBML.
// Versión: 2026-05-17
// Cambios desde v6.x:
//   - Renames: Skill→Topic, Item→Exercise, Classroom→Course, etc.
//   - Nuevos: Organization, School (refactor), Subject, Curriculum, Unit,
//     Topic, Enrollment, Exercise, Assignment, AttemptStep, ErrorTag,
//     StudentTopicMastery, SchoolIntegration, ExternalIdMap.
//   - Auth: supabase_uid reemplaza cognito_sub.
// =====================================================================

Project superprofes_db {
  database_type: 'PostgreSQL'
  Note: '''
    SuperProfes — backend serverless v7.1
    - Multi-tenant: Organization → School → Course → Enrollment → Student.
    - Multi-materia: Subject + Curriculum + Unit + Topic.
    - Trazabilidad de error: Attempt → AttemptStep, error_tag_id FK.
    - Integraciones SIS/LMS: SchoolIntegration + ExternalIdMap.
  '''
}

// =====================================================================
// AUTH / USERS
// =====================================================================

Table user {
  id              uuid       [pk, default: `gen_random_uuid()`]
  supabase_uid    uuid       [unique, not null, note: 'auth.users.id en Supabase']
  email           varchar    [unique, not null]
  full_name       varchar
  locale          varchar    [default: 'es-CL']
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
  deleted_at      timestamptz

  Indexes {
    email
    supabase_uid
  }
}

Table teacher {
  id              uuid       [pk, default: `gen_random_uuid()`]
  user_id         uuid       [unique, not null, ref: > user.id]
  display_name    varchar
  bio             text
  created_at      timestamptz [not null, default: `now()`]
}

Table student {
  id              uuid       [pk, default: `gen_random_uuid()`]
  user_id         uuid       [unique, ref: > user.id, note: 'NULL hasta que el alumno active su cuenta Supabase']
  external_email  varchar    [note: 'email del roster sync antes de activación']
  display_name    varchar    [not null]
  birth_year      int        [note: 'sin fecha exacta — privacy']
  created_at      timestamptz [not null, default: `now()`]
  deleted_at      timestamptz
}

Table parent {
  id              uuid       [pk, default: `gen_random_uuid()`]
  user_id         uuid       [unique, not null, ref: > user.id]
  display_name    varchar
  created_at      timestamptz [not null, default: `now()`]
}

Table parent_link {
  parent_id       uuid       [not null, ref: > parent.id]
  student_id      uuid       [not null, ref: > student.id]
  relationship    varchar    [not null, note: 'PADRE | MADRE | TUTOR']
  confirmed_at    timestamptz

  Indexes {
    (parent_id, student_id) [pk]
  }
}

// =====================================================================
// ORGANIZACIÓN ESCOLAR (multi-tenant)
// =====================================================================

Table organization {
  id              uuid       [pk, default: `gen_random_uuid()`]
  name            varchar    [not null]
  country         varchar    [not null, default: 'CL']
  billing_email   varchar
  plan            varchar    [not null, default: 'FREE', note: 'FREE | PILOT | PRO']
  created_at      timestamptz [not null, default: `now()`]
  Note: 'Una Organization agrupa N Schools (red de colegios) o sólo 1 (colegio independiente).'
}

Table school {
  id              uuid       [pk, default: `gen_random_uuid()`]
  organization_id uuid       [not null, ref: > organization.id]
  name            varchar    [not null]
  rbd             varchar    [unique, note: 'Rol Base de Datos chileno. NULL si fuera de Chile.']
  city            varchar
  region          varchar
  domain          varchar    [note: 'ej. @saintandrew.cl para auto-assign por email']
  created_at      timestamptz [not null, default: `now()`]

  Indexes {
    organization_id
    domain
  }
}

Table course {
  id              uuid       [pk, default: `gen_random_uuid()`]
  school_id       uuid       [not null, ref: > school.id]
  subject_id      uuid       [not null, ref: > subject.id]
  name            varchar    [not null, note: 'ej. "4to básico A"']
  grade_level     int        [not null, note: '1..12']
  academic_year   int        [not null]
  external_id     varchar    [note: 'ID original en Google Classroom / Teams / SIS']
  created_at      timestamptz [not null, default: `now()`]
  archived_at     timestamptz

  Indexes {
    (school_id, academic_year)
    subject_id
  }
}

Table course_teacher {
  course_id       uuid       [not null, ref: > course.id]
  teacher_id      uuid       [not null, ref: > teacher.id]
  role            varchar    [not null, default: 'LEAD', note: 'LEAD | ASSISTANT']
  added_at        timestamptz [not null, default: `now()`]

  Indexes {
    (course_id, teacher_id) [pk]
  }
}

Table enrollment {
  id              uuid       [pk, default: `gen_random_uuid()`]
  course_id       uuid       [not null, ref: > course.id]
  student_id      uuid       [not null, ref: > student.id]
  status          varchar    [not null, default: 'ACTIVE', note: 'ACTIVE | TRANSFERRED | LEFT']
  joined_at       timestamptz [not null, default: `now()`]
  left_at         timestamptz

  Indexes {
    (course_id, student_id) [unique]
    student_id
  }
}

// =====================================================================
// CURRICULUM (multi-materia, multi-grado)
// =====================================================================

Table subject {
  id              uuid       [pk, default: `gen_random_uuid()`]
  code            varchar    [unique, not null, note: 'MATH | LANG | SCIENCE | ...']
  name            varchar    [not null]
  language        varchar    [not null, default: 'es']
}

Table curriculum {
  id              uuid       [pk, default: `gen_random_uuid()`]
  subject_id      uuid       [not null, ref: > subject.id]
  country         varchar    [not null, default: 'CL']
  name            varchar    [not null, note: 'ej. "Matemáticas básica chilena 3°-6° 2026"']
  version         varchar    [not null, default: '1.0']
  effective_from  date
  effective_to    date

  Indexes {
    (subject_id, country, version) [unique]
  }
}

Table unit {
  id              uuid       [pk, default: `gen_random_uuid()`]
  curriculum_id   uuid       [not null, ref: > curriculum.id]
  grade_level     int        [not null]
  sequence        int        [not null, note: 'orden dentro del año']
  code            varchar    [not null, note: 'ej. U3-FRACCIONES']
  name            varchar    [not null]
  description     text

  Indexes {
    (curriculum_id, grade_level, sequence)
    (curriculum_id, code) [unique]
  }
}

Table topic {
  id                uuid     [pk, default: `gen_random_uuid()`]
  unit_id           uuid     [not null, ref: > unit.id]
  code              varchar  [not null, note: 'ej. T-FRAC-SUMA-IGUAL-DENOM']
  name              varchar  [not null]
  description       text
  bkt_p_l0          float    [not null, default: 0.3]
  bkt_p_transit     float    [not null, default: 0.1]
  bkt_p_slip        float    [not null, default: 0.1]
  bkt_p_guess       float    [not null, default: 0.2]
  bkt_calibrated_at timestamptz

  Indexes {
    (unit_id, code) [unique]
  }
}

Table topic_prerequisite {
  topic_id              uuid [not null, ref: > topic.id]
  prerequisite_topic_id uuid [not null, ref: > topic.id]
  Indexes {
    (topic_id, prerequisite_topic_id) [pk]
  }
}

// =====================================================================
// EJERCICIOS Y ASIGNACIONES
// =====================================================================

Table exercise {
  id              uuid       [pk, default: `gen_random_uuid()`]
  topic_id        uuid       [not null, ref: > topic.id]
  source          varchar    [not null, default: 'SYSTEM', note: 'SYSTEM | TEACHER_AUTHORED | LLM_GENERATED']
  created_by_teacher_id uuid [ref: > teacher.id]
  content         jsonb      [not null, note: '{ prompt, canonical_steps[], expected_answer, hints[] }']
  language        varchar    [not null, default: 'es']
  irt_a           float      [not null, default: 1.0]
  irt_b           float      [not null, default: 0.0]
  irt_calibrated_at timestamptz
  status          varchar    [not null, default: 'ACTIVE', note: 'DRAFT | ACTIVE | DEPRECATED']
  created_at      timestamptz [not null, default: `now()`]

  Indexes {
    (topic_id, source)
    (topic_id, status)
  }
}

Table assignment {
  id                    uuid [pk, default: `gen_random_uuid()`]
  course_id             uuid [ref: > course.id, note: 'asignación al curso completo']
  created_by_teacher_id uuid [not null, ref: > teacher.id]
  title                 varchar [not null]
  reason                varchar [not null, note: 'TEACHER_MANUAL | PRACTICE_RECOMMENDER']
  due_at                timestamptz
  created_at            timestamptz [not null, default: `now()`]

  Indexes {
    course_id
    created_by_teacher_id
  }
}

Table assignment_target {
  assignment_id   uuid       [not null, ref: > assignment.id]
  student_id      uuid       [not null, ref: > student.id]
  status          varchar    [not null, default: 'PENDING', note: 'PENDING | IN_PROGRESS | DONE']

  Indexes {
    (assignment_id, student_id) [pk]
    student_id
  }
  Note: 'Si vacío para una assignment con course_id seteado, aplica a todo el curso.'
}

Table assignment_exercise {
  assignment_id   uuid       [not null, ref: > assignment.id]
  exercise_id     uuid       [not null, ref: > exercise.id]
  sequence        int        [not null]

  Indexes {
    (assignment_id, sequence) [pk]
  }
}

// =====================================================================
// INTENTOS Y TELEMETRÍA RELACIONAL
// =====================================================================

Table attempt {
  id                  uuid       [pk, default: `gen_random_uuid()`]
  assignment_id       uuid       [ref: > assignment.id]
  exercise_id         uuid       [not null, ref: > exercise.id]
  student_id          uuid       [not null, ref: > student.id]
  course_id           uuid       [not null, ref: > course.id]
  input_mode          varchar    [not null, note: 'DIGITAL | PHOTO_OCR']
  status              varchar    [not null, default: 'PENDING', note: 'PENDING | PENDING_OCR | OCR_DONE | CLASSIFIED | LOW_CONFIDENCE_REVIEW']
  final_answer        text
  is_correct          boolean
  classifier_source   varchar    [note: 'RULE | LLM | OCR_PASSTHROUGH']
  error_tag_id        uuid       [ref: > error_tag.id]
  confidence          float
  ocr_confidence      float
  ocr_provider        varchar    [note: 'GEMINI | CLAUDE']
  llm_job_id          uuid
  trace_id            uuid       [not null]
  created_at          timestamptz [not null, default: `now()`]
  classified_at       timestamptz

  Indexes {
    student_id
    course_id
    (exercise_id, created_at)
    (assignment_id, student_id)
    error_tag_id
  }
}

Table attempt_step {
  id              uuid       [pk, default: `gen_random_uuid()`]
  attempt_id      uuid       [not null, ref: > attempt.id]
  step_index      int        [not null]
  content_latex   text       [not null]
  duration_ms     int
  is_correct      boolean
  error_subtag    varchar
  created_at      timestamptz [not null, default: `now()`]

  Indexes {
    (attempt_id, step_index) [unique]
  }
}

Table error_tag {
  id              uuid       [pk, default: `gen_random_uuid()`]
  code            varchar    [unique, not null, note: 'ej. SUB_BORROW_FORGOT_DECREMENT']
  topic_scope     varchar    [note: 'NULL = aplica multi-topic']
  description     text       [not null]
  severity        varchar    [not null, default: 'MED', note: 'LOW | MED | HIGH']
  created_at      timestamptz [not null, default: `now()`]
  Note: 'Sincronizado con docs/error-taxonomy.md y con prompts del ai-engine.'
}

// =====================================================================
// MASTERY
// =====================================================================

Table student_topic_mastery {
  student_id      uuid       [not null, ref: > student.id]
  topic_id        uuid       [not null, ref: > topic.id]
  p_known         float      [not null, default: 0.3]
  p_slip          float      [not null, default: 0.1]
  p_guess         float      [not null, default: 0.2]
  p_transit       float      [not null, default: 0.1]
  attempts_count  int        [not null, default: 0]
  last_attempt_at timestamptz
  trend_7d        float      [note: 'delta de p_known en últimos 7 días, recalculado por Alert Generator']
  updated_at      timestamptz [not null, default: `now()`]

  Indexes {
    (student_id, topic_id) [pk]
    topic_id
    last_attempt_at
  }
}

// =====================================================================
// ALERTS
// =====================================================================

Table teacher_alert {
  id              uuid       [pk, default: `gen_random_uuid()`]
  teacher_id      uuid       [not null, ref: > teacher.id]
  course_id       uuid       [not null, ref: > course.id]
  topic_id        uuid       [ref: > topic.id]
  student_id      uuid       [ref: > student.id]
  alert_type      varchar    [not null, note: 'AT_RISK_STUDENT | COMMON_ERROR_IN_TOPIC | STUDENT_DROP | UNIT_OFF_TRACK']
  severity        varchar    [not null, default: 'MED', note: 'LOW | MED | HIGH']
  payload         jsonb      [not null]
  created_at      timestamptz [not null, default: `now()`]
  resolved_at     timestamptz
  resolved_by     uuid       [ref: > teacher.id]

  Indexes {
    (teacher_id, resolved_at)
    (course_id, alert_type, created_at)
    (alert_type, topic_id, student_id, created_at) [note: 'usado por Alert Generator para dedup diaria']
  }
}

// =====================================================================
// INTEGRACIONES SIS/LMS  (Google Classroom, Teams Edu, Clever, CSV)
// =====================================================================

Table school_integration {
  id                      uuid       [pk, default: `gen_random_uuid()`]
  school_id               uuid       [not null, ref: > school.id]
  provider                varchar    [not null, note: 'GOOGLE_CLASSROOM | MS_TEAMS_EDU | CLEVER | CLASSLINK | CSV_MANUAL']
  status                  varchar    [not null, default: 'DRAFT', note: 'DRAFT | CONNECTED | SYNCING | ERROR | DISABLED']
  cadence                 varchar    [not null, default: 'MANUAL', note: 'MANUAL | DAILY | HOURLY']
  config                  jsonb      [not null, default: `'{}'::jsonb`, note: 'OAuth tokens cifrados con AWS KMS, district_id, scopes, domain']
  last_sync_at            timestamptz
  last_sync_error         text
  created_by_teacher_id   uuid       [ref: > teacher.id]
  created_at              timestamptz [not null, default: `now()`]
  updated_at              timestamptz [not null, default: `now()`]

  Indexes {
    (school_id, provider) [unique]
    status
  }
}

Table external_id_map {
  id                      uuid       [pk, default: `gen_random_uuid()`]
  school_integration_id   uuid       [not null, ref: > school_integration.id]
  provider                varchar    [not null]
  external_entity_type    varchar    [not null, note: 'STUDENT | TEACHER | COURSE | ENROLLMENT']
  external_id             varchar    [not null]
  internal_entity_type    varchar    [not null]
  internal_entity_id      uuid       [not null]
  first_seen_at           timestamptz [not null, default: `now()`]
  last_seen_at            timestamptz [not null, default: `now()`]
  deleted_at              timestamptz [note: 'soft-delete cuando el upstream lo elimina; re-aparición puede reactivar']

  Indexes {
    (provider, external_entity_type, external_id, school_integration_id) [unique]
    (internal_entity_type, internal_entity_id)
  }
  Note: 'Permite re-sync idempotente: si el externalId ya existe → UPSERT en interno, no se duplica.'
}

// =====================================================================
// INVITACIONES (clase y plataforma)
// =====================================================================

Table classroom_invite {
  id              uuid       [pk, default: `gen_random_uuid()`]
  course_id       uuid       [not null, ref: > course.id]
  email           varchar    [not null]
  role            varchar    [not null, note: 'STUDENT | TEACHER | PARENT']
  token           varchar    [unique, not null]
  expires_at      timestamptz [not null]
  accepted_at     timestamptz
  created_at      timestamptz [not null, default: `now()`]

  Indexes {
    course_id
    email
  }
}
