Project Innova_Relational {
  database_type: 'PostgreSQL'
}

Table User {
  id String [pk, note: 'UUID']
  email String [unique]
  role String [default: 'STUDENT', note: 'STUDENT, TEACHER, ADMIN']
  createdAt DateTime [default: `now()`]
  updatedAt DateTime
}

Table FslsmProfile {
  id String [pk, note: 'UUID']
  userId String [unique, ref: - User.id]
  active Int [default: 0, note: 'Active-Reflective (-11 to +11)']
  sensing Int [default: 0, note: 'Sensing-Intuitive (-11 to +11)']
  visual Int [default: 0, note: 'Visual-Verbal (-11 to +11)']
  sequential Int [default: 0, note: 'Sequential-Global (-11 to +11)']
  lastCalculated DateTime [default: `now()`]
  createdAt DateTime [default: `now()`]
  updatedAt DateTime
}
